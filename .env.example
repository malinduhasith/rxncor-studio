# Public app settings. These are safe to expose in the browser.
NEXT_PUBLIC_SITE_URL=https://rxncor.studio
NEXT_PUBLIC_CONTACT_EMAIL=hello@rxncor.studio
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_LOCATION=Melbourne, Australia
NEXT_PUBLIC_INSTAGRAM_HANDLE=@MR.Rxncor
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/mr.rxncor
NEXT_PUBLIC_FACEBOOK_HANDLE=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_THREADS_HANDLE=
NEXT_PUBLIC_THREADS_URL=
NEXT_PUBLIC_LINKEDIN_HANDLE=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_YOUTUBE_HANDLE=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://cdn.rxncor.studio

# Email notifications. Use Resend with a verified sending domain/subdomain.
RESEND_API_KEY=
EMAIL_FROM=rxncor.studio <hello@mail.rxncor.studio>
EMAIL_REPLY_TO=hello@rxncor.studio
ADMIN_NOTIFICATION_EMAIL=malinduhasith@gmail.com
ADMIN_EMAILS=malinduhasith@gmail.com

# Supabase. Get these from Supabase -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=

# New Supabase projects usually show a publishable key and secret key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Older Supabase projects/tutorials may call these anon and service_role.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2. Get these from Cloudflare -> R2 -> API.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=rxncor-studio-photos
CLOUDFLARE_R2_PUBLIC_BASE_URL=https://cdn.rxncor.studio
